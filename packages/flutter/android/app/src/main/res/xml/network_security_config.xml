<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTPS siempre permitido -->
    <base-config cleartextTrafficPermitted="false"/>
    <!-- HTTP permitido solo para IPs de desarrollo local (live reload) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.0</domain>
        <domain includeSubdomains="false">100.113.48.59</domain>
        <!-- Agrega aquí tu IP local si difiere -->
    </domain-config>
</network-security-config>

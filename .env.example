# ── Base de datos PostgreSQL ─────────────────────────────────────────
DB_NAME=gymtracker
DB_USER=gymuser
DB_PASSWORD=cambia_esto_por_una_clave_segura

# ── JWT — genera con: openssl rand -base64 32 ────────────────────────
JWT_SECRET=cambia_esto_minimo_32_caracteres_aleatorios
JWT_REFRESH_SECRET=otra_cadena_diferente_minimo_32_caracteres

# ── Redis — genera con: openssl rand -base64 24 ──────────────────────
REDIS_PASSWORD=cambia_esto_por_password_redis_seguro

# ── Admin — protege el dashboard de colas (/api/admin/queues) ────────
# Genera con: openssl rand -base64 32
# Deja vacío para desactivar el panel en producción.
ADMIN_TOKEN=cambia_esto_por_token_admin_seguro

# ── Cifrado de API keys de IA ─────────────────────────────────────────
# Genera con: openssl rand -hex 32  (debe ser exactamente 64 caracteres hex = 32 bytes)
# Si no se define, las API keys se almacenan en texto plano (no recomendado en producción).
ENCRYPTION_KEY=

# ── Solo para desarrollo local (make dev) ────────────────────────────
# El Makefile reescribe @db:5432 → @localhost:5440 y @redis:6379 → @localhost:6390
# (Coolify ocupa 5432/6379 del host en VPS compartidos, así que el dev local usa 5440/6390).
# En producción (Docker Compose) DATABASE_URL lo arma el docker-compose.yml
# con las variables DB_* de arriba, apuntando al servicio "db".
DATABASE_URL="postgresql://gymuser:cambia_esto_por_una_clave_segura@db:5432/gymtracker?connection_limit=10&pool_timeout=10"
REDIS_URL="redis://:cambia_esto_por_password_redis_seguro@redis:6379"

# ── SMTP — envío de correos (verificación y reset de contraseña) ─────
# Sin SMTP_HOST los correos se imprimen en consola (útil en dev).
# Ejemplos de proveedores:
#   cPanel/Hostinger : SMTP_HOST=mail.tudominio.com  SMTP_PORT=465  SMTP_SECURE=true
#   Gmail            : SMTP_HOST=smtp.gmail.com      SMTP_PORT=587  SMTP_SECURE=false  (requiere App Password)
#   Mailtrap (dev)   : SMTP_HOST=sandbox.smtp.mailtrap.io  SMTP_PORT=2525  SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gym Tracker <no-reply@tudominio.com>"

# ── URL base del frontend (para los links en los correos) ────────────
# Producción: https://tuapp.com  |  Desarrollo: http://localhost:5173
APP_URL=http://localhost:5173

# ── Dominio público (solo prod) — usado para CORS ────────────────────
# Ej: gym-tracker.ludaisca.ddns.net  (sin protocolo)
APP_DOMAIN=

# ── Push notifications (VAPID) ───────────────────────────────────────
# Si están vacías, el backend genera unas en arranque y las guarda en SystemConfig.
# Para fijarlas explícitamente, genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tudominio.com
